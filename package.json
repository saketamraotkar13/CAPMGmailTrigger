{
  "name": "emailcapm",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "dependencies": {
    "@sap-cloud-sdk/connectivity": "^4.1.2",
    "@sap-cloud-sdk/mail-client": "^3.24.0",
    "@sap/cds": "^9",
    "@sap/jobs-client": "^1.9.1",
    "@sap/xsenv": "^3.4.0",
    "@sap/xssec": "^4.10.0",
    "exceljs": "^4.4.0",
    "express": "^4",
    "passport": "^0.7.0",
    "sap-cf-mailer": "^0.0.5"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-uisendmail": "cds watch --open uisendmail/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy emailcapm --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked"
      },
      "mailService": {
        "kind": "rest",
        "credentials": {
          "destination": "mail_destination",
          "forwardAuthToken": true
        }
      },
      "connectivity": true,
      "destinations": true
    },
    "server": {
      "index": true
    }
  },
  "workspaces": [
    "app/*"
  ]
}
